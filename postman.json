          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "var jsonData = pm.response.json();\r",
                  "// pm.request.body.raw is a string, needs parsing\r",
                  "var payload = JSON.parse(pm.request.body.raw);\r",
                  "pm.environment.set(\"TOKEN\", jsonData.token);\r",
                  "pm.environment.set(\"created_user_email\", payload.email);\r",
                  "pm.environment.set(\"created_user_pass\", payload.password);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
